        "name": "Uptime",
        "uuid": "e7ef072ba0b64427bc5fdd78d6eaaa1d",
        "key": "asterisk.uptime",
        "type": "DEPENDENT",
        "value_type": "FLOAT",
        "history": "90d",
        "trends": "365d",
        "triggers": [
          {
            "tags": [
              {
                "tag": "scope",
                "value": "availability"
              }
            ],
            "name": "Asterisk: Failed to fetch AMI page",
            "uuid": "9953e43acaa6429bb8515d1e211a867c",
            "expression": "nodata(/Asterisk by HTTP/asterisk.uptime,30m)=1",
            "priority": "WARNING",
            "description": "Zabbix has not received any data for items for the last 30 minutes."
          },
          {
            "tags": [
              {
                "tag": "scope",
                "value": "notice"
              }
            ],
            "name": "Asterisk: Service has been restarted",
            "uuid": "fe01f5919b424b5d85fb7ec7c5c39625",
            "expression": "last(/Asterisk by HTTP/asterisk.uptime)<10m",
            "priority": "INFO",
            "description": "Uptime is less than 10 minutes."
          }
        ]
      },
      {
        "tags": [
          {
            "tag": "component",
            "value": "system"
          }
        ],
